<!-- Header -->
<div class="px-4 py-3 text-[13px] font-medium text-foreground">Secrets</div>

<!-- Entries -->
<div class="border-t border-border divide-y divide-border">
  <!-- GitHub Token -->
  <div class="flex items-center justify-between gap-3 px-4 py-3">
    <div class="min-w-0 flex flex-col gap-0.5">
      <span class="text-[13px] font-medium text-foreground truncate">GitHub Token</span>
      <span class="text-[11px] text-muted-foreground truncate">GitHub API authentication</span>
    </div>
    <span class="text-[11px] font-medium text-muted-foreground border border-border px-2 py-0.5 rounded-full shrink-0">1Password</span>
  </div>

  <!-- Google OAuth -->
  <div class="flex items-center justify-between gap-3 px-4 py-3">
    <div class="min-w-0 flex flex-col gap-0.5">
      <span class="text-[13px] font-medium text-foreground truncate">Google OAuth Client Secret</span>
      <span class="text-[11px] text-muted-foreground truncate">Calendar & Gmail access</span>
    </div>
    <span class="text-[11px] font-medium text-muted-foreground border border-border px-2 py-0.5 rounded-full shrink-0">macOS Keychain</span>
  </div>

  <!-- Stripe Key -->
  <div class="flex items-center justify-between gap-3 px-4 py-3">
    <div class="min-w-0 flex flex-col gap-0.5">
      <span class="text-[13px] font-medium text-foreground truncate">Stripe Secret Key</span>
      <span class="text-[11px] text-muted-foreground truncate">Payment processing</span>
    </div>
    <span class="text-[11px] font-medium text-muted-foreground border border-border px-2 py-0.5 rounded-full shrink-0">1Password</span>
  </div>

  <!-- Cloudflare Token -->
  <div class="flex items-center justify-between gap-3 px-4 py-3">
    <div class="min-w-0 flex flex-col gap-0.5">
      <span class="text-[13px] font-medium text-foreground truncate">Cloudflare API Token</span>
      <span class="text-[11px] text-muted-foreground truncate">DNS & Workers deployment</span>
    </div>
    <span class="text-[11px] font-medium text-muted-foreground border border-border px-2 py-0.5 rounded-full shrink-0">macOS Keychain</span>
  </div>
</div>
