---
import SourcesWidget from './SourcesWidget'
---

<section id="sources" class="py-24 px-6">
  <div class="mx-auto max-w-5xl">
    <div class="mx-auto max-w-xl space-y-4 text-center mb-12">
      <h2 class="text-balance text-3xl font-semibold md:text-5xl">Works with your tools</h2>
      <p class="text-muted-foreground text-balance text-lg">Supports GraphQL, OpenAPI, MCPs, and CLIs. Paste a URL to see it in action.</p>
    </div>
    <SourcesWidget client:visible />
  </div>
</section>
