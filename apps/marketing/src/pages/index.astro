---
export const prerender = true
import Layout from '../layouts/Layout.astro'
import HeroDemo from '../components/HeroDemo'
import HarnessLogos from '../components/HarnessLogos.astro'
import InstallSnippet from '../components/InstallSnippet.astro'
import FeatureBentoCard from '../components/FeatureBentoCard.astro'
import ParallelizeCard from '../components/ParallelizeCard.astro'
import ReturnWhatYouNeedCard from '../components/ReturnWhatYouNeedCard.astro'
import SecretsManagerCard from '../components/SecretsManagerCard'
import PolicyManagerCard from '../components/PolicyManagerCard'
import SourcesSection from '../components/SourcesSection.astro'
import IntegrateSection from '../components/IntegrateSection.astro'
---

<Layout>
  <!-- Nav -->
  <nav id="nav" class="fixed top-0 left-0 right-0 z-50 px-6 transition-[background-color,backdrop-filter,box-shadow] duration-300">
    <div class="max-w-[1200px] mx-auto py-2 flex items-center justify-between">
      <!-- Logo -->
      <a href="/" class="text-lg font-semibold tracking-[-0.02em] text-[#111]">
        Ξxecutor
      </a>

      <!-- Nav links -->
      <div class="flex items-center gap-8">
        <div class="hidden sm:flex items-center gap-6">
          <a href="#features" class="text-[14px] text-[#666] hover:text-[#111] transition-colors">Features</a>
          <a href="#integrate" class="text-[14px] text-[#666] hover:text-[#111] transition-colors">SDK</a>
          <a href="#sources" class="text-[14px] text-[#666] hover:text-[#111] transition-colors">Sources</a>
        </div>
        <div class="flex items-center gap-3">
          <span id="release-badge" class="hidden text-[12px] text-[#999] whitespace-nowrap"></span>
          <a
            href="https://github.com/RhysSullivan/executor"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center w-9 h-9 rounded-full hover:bg-[#f0f0f0] transition-colors"
            aria-label="GitHub"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="#111">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <main class="relative min-h-screen flex flex-col items-center pt-20 pb-24 px-6 overflow-hidden">
    <!-- Background gradient circles — clustered bottom-right -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute right-[-5%] top-[50%] w-[180px] h-[180px] rounded-full bg-[#864CCA] opacity-60"></div>
      <div class="absolute right-[10%] top-[58%] w-[150px] h-[150px] rounded-full bg-[#EAC6D1] opacity-70"></div>
      <div class="absolute right-[2%] top-[68%] w-[170px] h-[170px] rounded-full bg-[#C86081] opacity-55"></div>
      <div class="absolute right-[-3%] top-[78%] w-[160px] h-[160px] rounded-full bg-[#58A9C6] opacity-60"></div>
      <div class="absolute left-[20%] top-[62%] w-[140px] h-[140px] rounded-full bg-[#6958D0] opacity-55"></div>
      <div class="absolute inset-0 backdrop-blur-[80px]"></div>
    </div>

    <!-- Hero: centered stacked layout -->
    <div class="max-w-[1200px] w-full flex flex-col items-center mt-12 lg:mt-20">
      <!-- Headline -->
      <h1 class="text-4xl lg:text-5xl font-semibold leading-[1.08] tracking-[-0.035em] text-[#111] text-center animate-blur-in">
        One unified MCP<br />to access your tools
      </h1>

      <!-- Subheadline -->
      <p class="text-[17px] leading-[1.6] text-[#666] max-w-[520px] text-center mt-5 animate-blur-in-d1">
        Add credentials once, use in every agent. Fast and secure.
      </p>

      <!-- Install snippet -->
      <div class="w-full max-w-[480px] mt-8 animate-blur-in-d2">
        <InstallSnippet />
      </div>

      <!-- Terminal demo -->
      <div class="relative w-full mt-12 animate-blur-in-d3" style="min-height: 420px;">
        <HeroDemo client:only="react" />
      </div>

      <!-- Harness logos — bottom-left -->
      <div class="w-full mt-6 animate-blur-in-d4">
        <HarnessLogos />
      </div>
    </div>

  </main>

  <!-- Sources -->
  <SourcesSection />

  <!-- Features -->
  <div id="features">
    <FeatureBentoCard
      subtitle="Speed"
      subtitleColor="oklch(74% 0.238 322.16)"
      leftTitle="Fast Tool Calling"
      leftDescription="MCP tool calls run one at a time. Code mode lets you fire them all at once with Promise.all, cutting wait time to the slowest call."
      rightTitle="Return what you need"
      rightSubtitle="Cost"
      rightSubtitleColor="oklch(76.9% 0.188 70.08)"
      rightDescription="MCP tools return entire payloads. Code mode lets you pick exactly what matters, reducing token usage by up to 95% and avoiding lost-in-the-middle issues."
    >
      <ParallelizeCard slot="left" />
      <ReturnWhatYouNeedCard slot="right" />
    </FeatureBentoCard>

    <FeatureBentoCard
      leftSubtitle="Security"
      leftSubtitleColor="oklch(63.7% 0.237 25.33)"
      leftTitle="Secrets Manager"
      leftDescription="Use local tools like 1Password and macOS Keychain to manage your secrets. No plaintext env files, no shared vaults."
      rightTitle="Policy Manager"
      rightSubtitle="Security"
      rightSubtitleColor="oklch(63.7% 0.237 25.33)"
      rightDescription="Configure permissions by source, auto-approve reads, pause on writes if you want."
    >
      <SecretsManagerCard slot="left" client:visible />
      <PolicyManagerCard slot="right" client:visible />
    </FeatureBentoCard>
  </div>

  <!-- Integrate -->
  <IntegrateSection />

  <!-- CTA -->
  <section class="py-24 px-6">
    <div class="max-w-[1200px] mx-auto flex flex-col items-center text-center">
      <h2 class="text-3xl lg:text-4xl font-semibold tracking-[-0.035em] text-[#111]">
        Get started with Executor
      </h2>
      <p class="text-[17px] leading-[1.6] text-[#666] max-w-[480px] mt-4">
        Add credentials once, use in every agent. Install now and connect your first tool in minutes.
      </p>
      <div class="w-full max-w-[480px] mt-8">
        <InstallSnippet />
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t border-[#e5e5e5] py-8 px-6">
    <div class="max-w-[1200px] mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 text-[13px] text-[#999]">
      <span>&copy; {new Date().getFullYear()} Executor</span>
      <div class="flex items-center gap-6">
        <a href="/terms" class="hover:text-[#111] transition-colors">Terms</a>
        <a href="/privacy" class="hover:text-[#111] transition-colors">Privacy</a>
      </div>
    </div>
  </footer>

  <script>
    const nav = document.getElementById('nav')!;
    const onScroll = () => {
      if (window.scrollY > 20) {
        nav.classList.add('bg-[#FAFAFA]/80', 'backdrop-blur-lg', 'shadow-[0_0_0_1px_rgba(0,0,0,0.06)]');
      } else {
        nav.classList.remove('bg-[#FAFAFA]/80', 'backdrop-blur-lg', 'shadow-[0_0_0_1px_rgba(0,0,0,0.06)]');
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // Fetch latest release and show time-ago badge
    fetch('https://api.github.com/repos/RhysSullivan/executor/releases/latest')
      .then(r => r.json())
      .then(data => {
        if (!data.published_at) return;
        const badge = document.getElementById('release-badge');
        if (!badge) return;
        const diff = Date.now() - new Date(data.published_at).getTime();
        const hours = Math.floor(diff / 3_600_000);
        const days = Math.floor(hours / 24);
        const ago = days > 0 ? `${days}d ago` : `${hours}h ago`;
        badge.textContent = `${data.tag_name} · ${ago}`;
        badge.classList.remove('hidden');
      })
      .catch(() => {});
  </script>
</Layout>
